# GitHub Tokens — Required
# See README.md for minimum permission scopes per token.
#
# DISPATCHER_GH_TOKEN — used by dispatcher.py for polling issues, transitioning
#   labels, fetching PR context, and dismissing stale reviews.
#   Can be the same token as CODER or REVIEWER.
#   Minimum scopes: repo (issues read/write, pull requests read/write)
#
# CODER_GH_TOKEN — used by coding agents to push branches and open PRs.
#   Minimum scopes: repo (code read/write, pull requests read/write, issues read)
#
# REVIEWER_GH_TOKEN — used by review agents to approve or request changes on PRs.
#   Must be a DIFFERENT GitHub account from the coder (GitHub blocks self-approval).
#   The account must be added as a repo collaborator with Write access.
#   Minimum scopes: repo (pull requests read/write)
#
export DISPATCHER_GH_TOKEN=""
export CODER_GH_TOKEN=""
export REVIEWER_GH_TOKEN=""

# Notifications — Optional
export TELEGRAM_BOT_TOKEN=""
export TELEGRAM_CHAT_ID=""
export DISCORD_WEBHOOK_URL=""
