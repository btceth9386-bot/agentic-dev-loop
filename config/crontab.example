# Agentic Loop crontab setup
# Edit with: crontab -e
#
# Prerequisites — run once before setting up crontab:
#
#   cd /path/to/agentic-dev-loop
#   python3 -m venv .venv
#   .venv/bin/pip install pyyaml
#
# Then update the paths below and paste into crontab.

# Run dispatcher every 3 minutes
*/3 * * * * cd /path/to/agentic-dev-loop && source .env && .venv/bin/python3 dispatcher.py >> /tmp/agentic-loop.log 2>> /tmp/agentic-loop.error.log

# Run auto-merge every 3 minutes (offset by 90s to avoid overlap with dispatcher)
*/3 * * * * sleep 90 && cd /path/to/agentic-dev-loop && source .env && /bin/bash merge.sh >> /tmp/agentic-loop-merge.log 2>&1
